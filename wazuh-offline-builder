name: Build Wazuh Offline Bundle

on:
  workflow_dispatch:

env:
  FORCE_JAVASCRIPT_ACTIONS_TO_NODE24: true

jobs:
  build:
    runs-on: ubuntu-22.04

    steps:
      - name: Show runner info
        run: |
          whoami
          uname -a
          df -h
          free -h

      - name: Install tools
        run: |
          sudo apt-get update
          sudo apt-get install -y curl tar gnupg jq ca-certificates

      - name: Download Wazuh install assistant and official config template
        run: |
          cd "$HOME"
          curl -fL -O https://packages.wazuh.com/4.14/wazuh-install.sh
          curl -fL -O https://packages.wazuh.com/4.14/config.yml
          chmod 744 wazuh-install.sh
          ls -l wazuh-install.sh config.yml

      - name: Replace all-in-one placeholders in official config.yml
        run: |
          cd "$HOME"
          sed -i 's#<indexer-node-ip>#127.0.0.1#g' config.yml
          sed -i 's#<wazuh-manager-ip>#127.0.0.1#g' config.yml
          sed -i 's#<dashboard-node-ip>#127.0.0.1#g' config.yml
          echo "----- edited config.yml -----"
          cat config.yml

      - name: Copy files into /root
        run: |
          sudo cp "$HOME"/wazuh-install.sh /root/wazuh-install.sh
          sudo cp "$HOME"/config.yml /root/config.yml
          sudo chmod 744 /root/wazuh-install.sh
          echo "----- /root/config.yml -----"
          sudo cat /root/config.yml

      - name: Build offline package bundle
        run: |
          sudo bash -c 'cd /root && ./wazuh-install.sh -dw deb -da amd64'

      - name: Show root directory after download step
        run: |
          sudo bash -c 'ls -lah /root && echo "----- /root/config.yml -----" && cat /root/config.yml'

      - name: Generate install files bundle
        run: |
          set +e
          sudo bash -c 'cd /root && ./wazuh-install.sh -g'
          status=$?
          echo "wazuh-install.sh -g exit code: $status"
          sudo ls -lh /root/wazuh-install-files.tar /root/wazuh-offline.tar.gz /root/config.yml /root/wazuh-install.sh
          if sudo test -f /root/wazuh-install-files.tar; then
            echo "wazuh-install-files.tar exists, continuing."
            exit 0
          fi
          exit $status

      - name: Copy outputs back to runner home
        run: |
          sudo cp /root/wazuh-install.sh "$HOME"/
          sudo cp /root/config.yml "$HOME"/
          sudo cp /root/wazuh-offline.tar.gz "$HOME"/
          sudo cp /root/wazuh-install-files.tar "$HOME"/
          sudo chown $USER:$USER \
            "$HOME"/wazuh-install.sh \
            "$HOME"/config.yml \
            "$HOME"/wazuh-offline.tar.gz \
            "$HOME"/wazuh-install-files.tar

      - name: Show generated files
        run: |
          cd "$HOME"
          ls -lh
          test -f wazuh-offline.tar.gz
          test -f wazuh-install-files.tar
          test -f config.yml
          test -f wazuh-install.sh

      - name: Download latest vulnerability snapshot
        run: |
          cd "$HOME"
          SNAPSHOT_URL="$(curl -fsSL https://cti.wazuh.com/api/v1/catalog/contexts/vd_1.0.0/consumers/vd_4.8.0 | jq -r '.data.last_snapshot_link')"
          echo "$SNAPSHOT_URL"
          curl -fL "$SNAPSHOT_URL" -o cves.zip
          ls -lh cves.zip

      - name: Package outputs
        run: |
          cd "$HOME"
          sha256sum wazuh-install.sh config.yml wazuh-offline.tar.gz wazuh-install-files.tar cves.zip > checksums.txt
          tar -czf wazuh-offline-output.tar.gz \
            wazuh-install.sh \
            config.yml \
            wazuh-offline.tar.gz \
            wazuh-install-files.tar \
            cves.zip \
            checksums.txt
          ls -lh wazuh-offline-output.tar.gz checksums.txt

      - name: Upload output artifact
        uses: actions/upload-artifact@v4
        with:
          name: wazuh-offline-output
          path: ~/wazuh-offline-output.tar.gz

      - name: Copy Wazuh log to readable location on failure
        if: failure()
        run: |
          sudo cp /var/log/wazuh-install.log "$HOME"/wazuh-install.log || true
          sudo chown $USER:$USER "$HOME"/wazuh-install.log || true
          ls -lh "$HOME"/wazuh-install.log || true

      - name: Upload Wazuh log on failure
        if: failure()
        uses: actions/upload-artifact@v4
        with:
          name: wazuh-install-log
          path: ~/wazuh-install.log
          if-no-files-found: ignore
